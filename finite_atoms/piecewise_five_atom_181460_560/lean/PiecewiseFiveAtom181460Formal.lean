theorem tailParamBlocks_cover : ParamBlock.CoversFrom tailParamBlocks rB rM := by
  native_decide

theorem tailParamBlocks_idx_lt : ∀ b, b ∈ tailParamBlocks → b.idx < K := by
  native_decide

theorem tailParamBlocks_consistent :
    ∀ b, b ∈ tailParamBlocks → b.L = piecewiseBlockParamLRat b.idx ∧
      b.R = piecewiseBlockParamRRat b.idx := by
  native_decide

theorem tailParamBlocks_weights_nonneg :
    ∀ b, b ∈ tailParamBlocks →
      0 ≤ piecewiseBlockWeight1Rat b.idx ∧ 0 ≤ piecewiseBlockWeight2Rat b.idx ∧
      0 ≤ piecewiseBlockWeight3Rat b.idx ∧ 0 ≤ piecewiseBlockWeight4Rat b.idx := by
  native_decide

/-- The generated chunk parameter intervals cover the full tail interval `[B,M]`. -/
theorem piecewise_chunk_cover_tail {r : ℝ} (hr : r ∈ Icc B M) :
    ∃ b ∈ tailParamBlocks, r ∈ Icc (b.L : ℝ) (b.R : ℝ) := by
  have hr' : r ∈ Icc (rB : ℝ) (rM : ℝ) := by
    simpa [rB_cast, rM_cast] using hr
  exact ParamBlock.mem_of_coversFrom tailParamBlocks_cover hr'

/-- Select a verified chunk for the tail parameter `a`. -/
noncomputable def piecewiseTailBlock (a : ℝ) : ParamBlock :=
  if htail : -a ∈ Icc B M then Classical.choose (piecewise_chunk_cover_tail htail)
  else default

noncomputable def piecewiseTailBlockIndex (a : ℝ) : Nat :=
  (piecewiseTailBlock a).idx

lemma neg_mem_tail_of_parameter {a : ℝ} (ha : a ∈ Icc (-M) (-B)) :
    -a ∈ Icc B M := by
  constructor <;> linarith [ha.1, ha.2]

lemma piecewiseTailBlock_mem {a : ℝ} (ha : a ∈ Icc (-M) (-B)) :
    piecewiseTailBlock a ∈ tailParamBlocks := by
  have htail : -a ∈ Icc B M := neg_mem_tail_of_parameter ha
  have hspec := Classical.choose_spec (piecewise_chunk_cover_tail htail)
  simpa [piecewiseTailBlock, htail] using hspec.1

lemma piecewiseTailBlock_raw_param_mem {a : ℝ} (ha : a ∈ Icc (-M) (-B)) :
    -a ∈ Icc ((piecewiseTailBlock a).L : ℝ) ((piecewiseTailBlock a).R : ℝ) := by
  have htail : -a ∈ Icc B M := neg_mem_tail_of_parameter ha
  have hspec := Classical.choose_spec (piecewise_chunk_cover_tail htail)
  simpa [piecewiseTailBlock, htail] using hspec.2

lemma piecewiseTailBlockIndex_lt {a : ℝ} (ha : a ∈ Icc (-M) (-B)) :
    piecewiseTailBlockIndex a < K := by
  exact tailParamBlocks_idx_lt (piecewiseTailBlock a) (piecewiseTailBlock_mem ha)

lemma piecewiseTailBlockIndex_param_mem {a : ℝ} (ha : a ∈ Icc (-M) (-B)) :
    -a ∈ Icc (piecewiseBlockParamL (piecewiseTailBlockIndex a))
      (piecewiseBlockParamR (piecewiseTailBlockIndex a)) := by
  have hraw := piecewiseTailBlock_raw_param_mem ha
  have hc := tailParamBlocks_consistent (piecewiseTailBlock a) (piecewiseTailBlock_mem ha)
  rcases hc with ⟨hL, hR⟩
  simpa [piecewiseTailBlockIndex, piecewiseBlockParamL, piecewiseBlockParamR, hL, hR] using hraw

/-- The actual moving-tail weights as a function of the tail parameter `a`. -/
noncomputable def piecewiseTailWeights (a : ℝ) : Fin 5 → ℝ :=
  piecewiseBlockWeights (piecewiseTailBlockIndex a)

theorem piecewiseTailWeights_nonneg {a : ℝ} (ha : a ∈ Icc (-M) (-B)) :
    ∀ j : Fin 5, 0 ≤ piecewiseTailWeights a j := by
  have hw := tailParamBlocks_weights_nonneg (piecewiseTailBlock a) (piecewiseTailBlock_mem ha)
  intro j
  fin_cases j
  · simp [piecewiseTailWeights, piecewiseBlockWeights]
  · change 0 ≤ piecewiseBlockWeight1 (piecewiseTailBlockIndex a)
    unfold piecewiseBlockWeight1 piecewiseTailBlockIndex
    exact_mod_cast hw.1
  · change 0 ≤ piecewiseBlockWeight2 (piecewiseTailBlockIndex a)
    unfold piecewiseBlockWeight2 piecewiseTailBlockIndex
    exact_mod_cast hw.2.1
  · change 0 ≤ piecewiseBlockWeight3 (piecewiseTailBlockIndex a)
    unfold piecewiseBlockWeight3 piecewiseTailBlockIndex
    exact_mod_cast hw.2.2.1
  · change 0 ≤ piecewiseBlockWeight4 (piecewiseTailBlockIndex a)
    unfold piecewiseBlockWeight4 piecewiseTailBlockIndex
    exact_mod_cast hw.2.2.2

