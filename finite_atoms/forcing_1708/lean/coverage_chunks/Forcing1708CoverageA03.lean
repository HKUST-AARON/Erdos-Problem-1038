def defaultBox : BoxGeom := { aLo := 0, aHi := 0, sLo := 0, sHi := 0, xLo := 0, xHi := 0 }
def cellInsideBox (B : BoxGeom) (s0 s1 x0 x1 : Rat) : Bool :=
  decide (B.aLo ≤ aLo) && decide (aHi ≤ B.aHi) &&
  decide (B.sLo ≤ s0) && decide (s1 ≤ B.sHi) &&
  decide (B.xLo ≤ x0) && decide (x1 ≤ B.xHi)

def cellWitnessOk (W : CellWitness) : Bool :=
  decide (W.is + 1 < sBreaks.size) && decide (W.ix + 1 < xBreaks.size) && decide (W.bi < boxes.size) &&
  cellInsideBox (boxes.getD W.bi defaultBox)
    (sBreaks.getD W.is 0) (sBreaks.getD (W.is + 1) 0)
    (xBreaks.getD W.ix 0) (xBreaks.getD (W.ix + 1) 0)

def linearIndex (W : CellWitness) : Nat := W.is * xCells + W.ix
def witnessesOkFrom : Nat → List CellWitness → Bool
  | i, [] => decide (i = expectedCells)
  | i, W :: rest => cellWitnessOk W && decide (linearIndex W = i) && witnessesOkFrom (i + 1) rest

