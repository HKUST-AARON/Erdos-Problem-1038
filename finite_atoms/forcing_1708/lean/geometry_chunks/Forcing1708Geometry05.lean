structure BoxGeom where
  aLo : Rat
  aHi : Rat
  sLo : Rat
  sHi : Rat
  xLo : Rat
  xHi : Rat
  bLo : Rat
  bHi : Rat
deriving Repr, DecidableEq

def bOffset : Rat := Rat.normalize (182 : Int) (100 : Nat)
def cShift : Rat := Rat.normalize (1071 : Int) (1000 : Nat)

def absRat (x : Rat) : Rat := if x < 0 then -x else x
def maxRat (x y : Rat) : Rat := if x ≤ y then y else x
def dA (B : BoxGeom) : Rat := B.xHi - B.aLo
def dB (B : BoxGeom) : Rat := maxRat (absRat (B.xLo - B.bHi)) (absRat (B.xHi - B.bLo))
def cLo (B : BoxGeom) : Rat := cShift - B.bHi
def cHi (B : BoxGeom) : Rat := cShift - B.bLo
def dC (B : BoxGeom) : Rat := maxRat (absRat (B.xLo - cHi B)) (absRat (B.xHi - cLo B))

def geometryOk (B : BoxGeom) : Bool :=
  decide (B.aLo < B.aHi) && decide (B.sLo < B.sHi) && decide (B.xLo < B.xHi) &&
  decide (B.bLo ≤ B.sLo * (bOffset + B.aLo)) &&
  decide (B.sHi * (bOffset + B.aHi) ≤ B.bHi) &&
  decide (0 < dA B) && decide (0 < dB B) && decide (0 < dC B)

