  dB_dir : Int
  dB_k : Nat
  dC_dir : Int
  dC_k : Nat
  aLo_dir : Int
  aLo_k : Nat
  aHi_dir : Int
  aHi_k : Nat
  bLo_dir : Int
  bLo_k : Nat
  bHi_dir : Int
  bHi_k : Nat
  gLo_dir : Int
  gLo_k : Nat
  gHi_dir : Int
  gHi_k : Nat
deriving Repr, DecidableEq

def numeratorLower (B : BoxPre) : Rat :=
  -1/10000 - logUpperScaled B.aHi_dir B.aHi_k B.aHiDist - B.wHi * logUpperScaled B.bHi_dir B.bHi_k B.bHiDist
def numeratorUpper (B : BoxPre) : Rat :=
  -1/10000 - logLowerScaled B.aLo_dir B.aLo_k B.aLoDist - B.wLo * logLowerScaled B.bLo_dir B.bLo_k B.bLoDist
def denomLower (B : BoxPre) : Rat := logLowerScaled B.gLo_dir B.gLo_k B.gLoDist
def denomUpper (B : BoxPre) : Rat := logUpperScaled B.gHi_dir B.gHi_k B.gHiDist
def preconditionOk (B : BoxPre) : Bool :=
  decide (B.baseA ≤ -logUpperScaled B.dA_dir B.dA_k B.dA) &&
  decide (B.baseB ≤ -logUpperScaled B.dB_dir B.dB_k B.dB) &&
  decide (B.baseC ≤ -logUpperScaled B.dC_dir B.dC_k B.dC) &&
  decide (0 < numeratorLower B) && decide (0 < denomLower B) && decide (0 < denomUpper B) &&
  decide (B.cLo ≤ numeratorLower B / denomUpper B) &&
  decide (numeratorUpper B / denomLower B ≤ B.cHi)

