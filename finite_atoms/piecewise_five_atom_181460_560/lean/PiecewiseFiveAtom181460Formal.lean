def piecewiseBlockParamL (i : Nat) : ℝ := (piecewiseBlockParamLRat i : ℝ)
def piecewiseBlockParamR (i : Nat) : ℝ := (piecewiseBlockParamRRat i : ℝ)

def piecewiseBlockWeights (i : Nat) : Fin 5 → ℝ
  | ⟨0, _⟩ => 1
  | ⟨1, _⟩ => piecewiseBlockWeight1 i
  | ⟨2, _⟩ => piecewiseBlockWeight2 i
  | ⟨3, _⟩ => piecewiseBlockWeight3 i
  | ⟨4, _⟩ => piecewiseBlockWeight4 i

structure ParamBlock where
  idx : Nat
  L : Rat
  R : Rat
  deriving DecidableEq, Repr

instance : Inhabited ParamBlock := ⟨{ idx := 0, L := 0, R := 0 }⟩

def ParamBlock.coversFromBool : List ParamBlock → Rat → Rat → Bool
  | [], _lo, _hi => false
  | [b], lo, hi => decide (b.L ≤ lo ∧ hi ≤ b.R)
  | b :: b' :: bs, lo, hi =>
      decide (b.L ≤ lo ∧ lo ≤ b.R) && ParamBlock.coversFromBool (b' :: bs) b.R hi

def ParamBlock.CoversFrom (blocks : List ParamBlock) (lo hi : Rat) : Prop :=
  ParamBlock.coversFromBool blocks lo hi = true

instance (blocks : List ParamBlock) (lo hi : Rat) : Decidable (ParamBlock.CoversFrom blocks lo hi) := by
  unfold ParamBlock.CoversFrom
  infer_instance

lemma ParamBlock.mem_of_coversFrom
    {blocks : List ParamBlock} {lo hi : Rat}
    (hc : ParamBlock.CoversFrom blocks lo hi)
    {r : ℝ} (hr : r ∈ Icc (lo : ℝ) (hi : ℝ)) :
    ∃ b ∈ blocks, r ∈ Icc (b.L : ℝ) (b.R : ℝ) := by
  induction blocks generalizing lo with
  | nil =>
      simp [ParamBlock.CoversFrom, ParamBlock.coversFromBool] at hc
  | cons b bs ih =>
      cases bs with
      | nil =>
          have hcdec : decide (b.L ≤ lo ∧ hi ≤ b.R) = true := by
            simpa [ParamBlock.CoversFrom, ParamBlock.coversFromBool] using hc
          have hprop : b.L ≤ lo ∧ hi ≤ b.R := of_decide_eq_true hcdec
          rcases hprop with ⟨hbL, hhiR⟩
          refine ⟨b, by simp, ?_⟩
          constructor
          · have hbLR : (b.L : ℝ) ≤ (lo : ℝ) := by exact_mod_cast hbL
            linarith [hbLR, hr.1]
          · have hhiRR : (hi : ℝ) ≤ (b.R : ℝ) := by exact_mod_cast hhiR
            linarith [hhiRR, hr.2]
      | cons b' bs =>
          have hcbool :
              decide (b.L ≤ lo ∧ lo ≤ b.R) && ParamBlock.coversFromBool (b' :: bs) b.R hi = true := by
            simpa [ParamBlock.CoversFrom, ParamBlock.coversFromBool] using hc
          have hheadBool : decide (b.L ≤ lo ∧ lo ≤ b.R) = true := by
            cases h : decide (b.L ≤ lo ∧ lo ≤ b.R) <;> simp [h] at hcbool ⊢
          have hrest : ParamBlock.CoversFrom (b' :: bs) b.R hi := by
            unfold ParamBlock.CoversFrom
            cases h : decide (b.L ≤ lo ∧ lo ≤ b.R)
            · simp [h] at hcbool
            · simpa [h] using hcbool
          have hhead : b.L ≤ lo ∧ lo ≤ b.R := of_decide_eq_true hheadBool
          rcases hhead with ⟨hbL, hloR⟩
          by_cases hrR : r ≤ (b.R : ℝ)
          · refine ⟨b, by simp, ?_⟩
            constructor
            · have hbLR : (b.L : ℝ) ≤ (lo : ℝ) := by exact_mod_cast hbL
              linarith [hbLR, hr.1]
            · exact hrR
          · have hbRr : (b.R : ℝ) ≤ r := le_of_lt (lt_of_not_ge hrR)
            have hr' : r ∈ Icc (b.R : ℝ) (hi : ℝ) := ⟨hbRr, hr.2⟩
            rcases ih hrest hr' with ⟨b2, hb2mem, hb2r⟩
            exact ⟨b2, by simp [hb2mem], hb2r⟩

