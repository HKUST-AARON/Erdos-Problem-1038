def block305Boxes : List RatBox := block305LeftBoxes ++ block305RightBoxes

theorem block305_left_boxes_valid : ∀ b ∈ block305LeftBoxes, b.Valid := by
  native_decide

theorem block305_right_boxes_valid : ∀ b ∈ block305RightBoxes, b.Valid := by
  native_decide

theorem block305_left_boxes_same_weights : ∀ b ∈ block305LeftBoxes,
    RatBox.SameWeights b block305W1 block305W2 block305W3 block305W4 := by
  native_decide

theorem block305_right_boxes_same_weights : ∀ b ∈ block305RightBoxes,
    RatBox.SameWeights b block305W1 block305W2 block305W3 block305W4 := by
  native_decide

theorem block305_left_covers : RatBox.CoversFrom block305LeftBoxes block305LeftL block305LeftR := by
  native_decide

theorem block305_right_covers : RatBox.CoversFrom block305RightBoxes block305RightL block305RightR := by
  native_decide

theorem block305_required_pos
    {y : ℝ}
    (hy : y ∈ Icc (block305LeftL : ℝ) (block305LeftR : ℝ) ∪
          Icc (block305RightL : ℝ) (block305RightR : ℝ))
    (hy0ne : y ≠ 0)
    (hy1ne : y ≠ d1)
    (hy2ne : y ≠ d2)
    (hy3ne : y ≠ d3)
    (hy4ne : y ≠ d4) :
    0 < V (block305W1 : ℝ) (block305W2 : ℝ) (block305W3 : ℝ) (block305W4 : ℝ) y := by
  rcases hy with hy | hy
  · rcases RatBox.mem_of_coversFrom block305_left_covers hy with ⟨b, hb, hyb⟩
    have hv := block305_left_boxes_valid b hb
    have hsame := block305_left_boxes_same_weights b hb
    rcases hsame with ⟨hw1, hw2, hw3, hw4⟩
    have hp := V_pos_of_valid_ratbox hv hyb hy0ne hy1ne hy2ne hy3ne hy4ne
    simpa [block305W1, block305W2, block305W3, block305W4, hw1, hw2, hw3, hw4] using hp
  · rcases RatBox.mem_of_coversFrom block305_right_covers hy with ⟨b, hb, hyb⟩
