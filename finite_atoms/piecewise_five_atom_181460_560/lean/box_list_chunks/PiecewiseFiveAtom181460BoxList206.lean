    (hy1ne : y ≠ d1)
    (hy2ne : y ≠ d2)
    (hy3ne : y ≠ d3)
    (hy4ne : y ≠ d4) :
    0 < V (block206W1 : ℝ) (block206W2 : ℝ) (block206W3 : ℝ) (block206W4 : ℝ) y := by
  rcases hy with hy | hy
  · rcases RatBox.mem_of_coversFrom block206_left_covers hy with ⟨b, hb, hyb⟩
    have hv := block206_left_boxes_valid b hb
    have hsame := block206_left_boxes_same_weights b hb
