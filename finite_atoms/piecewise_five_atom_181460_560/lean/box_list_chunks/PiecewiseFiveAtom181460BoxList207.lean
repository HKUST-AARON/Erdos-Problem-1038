theorem block207_required_pos
    {y : ℝ}
    (hy : y ∈ Icc (block207LeftL : ℝ) (block207LeftR : ℝ) ∪
          Icc (block207RightL : ℝ) (block207RightR : ℝ))
    (hy0ne : y ≠ 0)
    (hy1ne : y ≠ d1)
    (hy2ne : y ≠ d2)
    (hy3ne : y ≠ d3)
    (hy4ne : y ≠ d4) :
    0 < V (block207W1 : ℝ) (block207W2 : ℝ) (block207W3 : ℝ) (block207W4 : ℝ) y := by
  rcases hy with hy | hy
  · rcases RatBox.mem_of_coversFrom block207_left_covers hy with ⟨b, hb, hyb⟩
    have hv := block207_left_boxes_valid b hb
    have hsame := block207_left_boxes_same_weights b hb
    rcases hsame with ⟨hw1, hw2, hw3, hw4⟩
    have hp := V_pos_of_valid_ratbox hv hyb hy0ne hy1ne hy2ne hy3ne hy4ne
    simpa [block207W1, block207W2, block207W3, block207W4, hw1, hw2, hw3, hw4] using hp
  · rcases RatBox.mem_of_coversFrom block207_right_covers hy with ⟨b, hb, hyb⟩
    have hv := block207_right_boxes_valid b hb
    have hsame := block207_right_boxes_same_weights b hb
