def nTerms : Nat := 12
def atanhLowerRat : Nat → Rat → Rat
  | 0, _ => 0
  | n + 1, t => atanhLowerRat n t + 2 * t ^ (2 * n + 1) / (2 * n + 1)

def atanhUpperRat (n : Nat) (t : Rat) : Rat :=
  atanhLowerRat n t + 2 * t ^ (2 * n + 1) / (1 - t ^ 2)

def tInv (d : Rat) : Rat := (1 - d) / (1 + d)
def tSelf (d : Rat) : Rat := (d - 1) / (d + 1)
def logLowerRat (n : Nat) (d : Rat) : Rat :=
  if d < 1 then -atanhUpperRat n (tInv d) else atanhLowerRat n (tSelf d)
def logUpperRat (n : Nat) (d : Rat) : Rat :=
  if d < 1 then -atanhLowerRat n (tInv d) else atanhUpperRat n (tSelf d)
def pow2Rat (k : Nat) : Rat := (2 : Rat) ^ k
def logLowerUp (k : Nat) (d : Rat) : Rat := logLowerRat nTerms (d * pow2Rat k) - (k : Rat) * logUpperRat nTerms 2
def logUpperUp (k : Nat) (d : Rat) : Rat := logUpperRat nTerms (d * pow2Rat k) - (k : Rat) * logLowerRat nTerms 2
def logLowerDown (k : Nat) (d : Rat) : Rat := logLowerRat nTerms (d / pow2Rat k) + (k : Rat) * logLowerRat nTerms 2
def logUpperDown (k : Nat) (d : Rat) : Rat := logUpperRat nTerms (d / pow2Rat k) + (k : Rat) * logUpperRat nTerms 2
def logLowerScaled (dir : Int) (k : Nat) (d : Rat) : Rat := if dir < 0 then logLowerUp k d else if dir > 0 then logLowerDown k d else logLowerRat nTerms d
def logUpperScaled (dir : Int) (k : Nat) (d : Rat) : Rat := if dir < 0 then logUpperUp k d else if dir > 0 then logUpperDown k d else logUpperRat nTerms d

