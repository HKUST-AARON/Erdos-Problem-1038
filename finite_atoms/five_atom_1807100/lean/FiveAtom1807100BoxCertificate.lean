        (by
          rw [abs_of_pos (sub_pos.mpr hs1y)]
          have hdist : ((qr (R - s1N) : Rat) : ℝ) = q R scaleN - s1 := by
            rw [s1_eq_q, qr_sub_cast hS1leR]
