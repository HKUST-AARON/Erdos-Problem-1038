theorem block198_required_pos
    {y : ℝ}
    (hy : y ∈ Icc (block198LeftL : ℝ) (block198LeftR : ℝ) ∪
          Icc (block198RightL : ℝ) (block198RightR : ℝ))
    (hy0ne : y ≠ 0)
    (hy1ne : y ≠ d1)
    (hy2ne : y ≠ d2)
    (hy3ne : y ≠ d3)
    (hy4ne : y ≠ d4) :
    0 < V (block198W1 : ℝ) (block198W2 : ℝ) (block198W3 : ℝ) (block198W4 : ℝ) y := by
  rcases hy with hy | hy
  · rcases RatBox.mem_of_coversFrom block198_left_covers hy with ⟨b, hb, hyb⟩
    have hv := block198_left_boxes_valid b hb
    have hsame := block198_left_boxes_same_weights b hb
    rcases hsame with ⟨hw1, hw2, hw3, hw4⟩
