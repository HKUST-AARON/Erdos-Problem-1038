        (by unfold qr scaleN; exact div_pos (by exact_mod_cast hRpos) (by norm_num))
        (by
          unfold qr scaleN
          have h : s1N < R := lt_of_le_of_lt (by native_decide : s1N ≤ s3N) hS3ltR
