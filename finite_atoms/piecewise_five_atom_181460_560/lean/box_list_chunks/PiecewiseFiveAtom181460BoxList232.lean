theorem block232_required_pos
    {y : ℝ}
    (hy : y ∈ Icc (block232LeftL : ℝ) (block232LeftR : ℝ) ∪
          Icc (block232RightL : ℝ) (block232RightR : ℝ))
    (hy0ne : y ≠ 0)
    (hy1ne : y ≠ d1)
    (hy2ne : y ≠ d2)
    (hy3ne : y ≠ d3)
    (hy4ne : y ≠ d4) :
    0 < V (block232W1 : ℝ) (block232W2 : ℝ) (block232W3 : ℝ) (block232W4 : ℝ) y := by
  rcases hy with hy | hy
  · rcases RatBox.mem_of_coversFrom block232_left_covers hy with ⟨b, hb, hyb⟩
    have hv := block232_left_boxes_valid b hb
